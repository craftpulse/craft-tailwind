{
    "name": "craftpulse/craft-tailwind",
    "description": "Tailwind CSS class merging and named-slot class builder for Craft CMS 5",
    "version": "5.0.1",
    "type": "craft-plugin",
    "license": "proprietary",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "tailwind",
        "tailwindcss",
        "css",
        "class-merging"
    ],
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0.0",
        "michtio/tailwind-merge-v3": "^1.2",
        "michtio/tailwind-merge-v4": "^0.3"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "craftpulse\\tailwind\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "craftpulse\\tailwind\\tests\\": "tests/"
        }
    },
    "extra": {
        "handle": "tailwind",
        "name": "Tailwind",
        "developer": "CraftPulse",
        "developerUrl": "https://craftpulse.com",
        "documentationUrl": "https://github.com/craftpulse/craft-tailwind",
        "class": "craftpulse\\tailwind\\Tailwind"
    },
    "scripts": {
        "phpstan": "phpstan --ansi --memory-limit=1G",
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --fix --ansi",
        "test": "pest --no-coverage --colors=always"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true,
            "pestphp/pest-plugin": true
        }
    }
}
