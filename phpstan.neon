includes:
    - vendor/craftcms/phpstan/phpstan.neon

parameters:
    level: 5
    # Stubs in craftcms/phpstan declare Craft::$app as non-nullable. That
    # holds in normal request handling but not in early bootstrap or in
    # unit-test scenarios that bypass the full app boot, so the defensive
    # `Craft::$app instanceof ...Application` checks in CssVariables and
    # VersionDetector stay load-bearing. Treat the stub-declared types as
    # advisory rather than certain so the checks aren't flagged dead.
    treatPhpDocTypesAsCertain: false
    paths:
        - src
