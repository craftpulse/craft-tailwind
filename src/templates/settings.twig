{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{# Layout reads this and renders the page-tabs strip; pane visibility and
   #hash switching are wired up by Craft's CP JS. No manual tab markup
   or JS toggle on our side. #}
{% set tabs = {
    detection: { label: 'Detection'|t('tailwind'), url: '#detection' },
    output: { label: 'Output'|t('tailwind'), url: '#output' },
    typography: { label: 'Typography'|t('tailwind'), url: '#typography' },
} %}
{% set selectedTab = 'detection' %}

{% set fullPageForm = not readOnly %}

{% if readOnly %}
    {% set contentNotice = readOnlyNotice() %}
{% endif %}

{% macro overrideWarning(key, overrides) -%}
    {%- if overrides[key] is defined -%}
        {{- 'This setting is overridden by `config/tailwind.php`.'|t('tailwind') -}}
    {%- endif -%}
{%- endmacro %}

{% from _self import overrideWarning %}

{% block actionButton %}
    {% if not readOnly %}
        <input type="submit" class="btn submit" value="{{ 'Save'|t('app') }}">
    {% endif %}
{% endblock %}

{% block content %}
    {% if not readOnly %}
        {{ actionInput('tailwind/settings/save') }}
        {{ hiddenInput('pluginHandle', 'tailwind') }}
        {{ redirectInput('settings/plugins/tailwind') }}
    {% endif %}

    {# ===== Detection tab ===== #}
    <div id="detection">
        {{ forms.selectField({
            label: 'Tailwind Version',
            instructions: 'Choose which Tailwind version to use for class merging. "Auto" detects the version from your project files.',
            id: 'tailwindVersion',
            name: 'settings[tailwindVersion]',
            value: settings.tailwindVersion,
            options: [
                { label: 'Auto-detect', value: 'auto' },
                { label: 'Tailwind v3', value: '3' },
                { label: 'Tailwind v4', value: '4' },
            ],
            errors: settings.getErrors('tailwindVersion'),
            disabled: overrides.tailwindVersion is defined or readOnly,
            warning: overrideWarning('tailwindVersion', overrides),
        }) }}

        <div id="autoDetect-feedback"{% if settings.tailwindVersion != 'auto' %} style="display:none"{% endif %}>
            {% if autoDetectReason == 'fallback' %}
                <p class="notice">No Tailwind signals found in this project. Falling back to <strong>Tailwind v4</strong>.</p>
            {% else %}
                <p class="notice">Auto-detected: <strong>Tailwind v{{ autoDetectVersion }}</strong>{% if autoDetectReason %} via <code>{{ autoDetectReason }}</code>{% endif %}.</p>
            {% endif %}
        </div>

        {{ forms.autosuggestField({
            label: 'Buildchain Path',
            instructions: 'Directory containing your `tailwind.config.*` files. Used for v3 detection (or v4 projects with a JS config). Leave blank to search from the project root.',
            id: 'buildchainPath',
            name: 'settings[buildchainPath]',
            value: settings.buildchainPath,
            placeholder: 'e.g. @root/buildchain',
            suggestEnvVars: true,
            suggestAliases: true,
            errors: settings.getErrors('buildchainPath'),
            disabled: overrides.buildchainPath is defined or readOnly,
            warning: overrideWarning('buildchainPath', overrides),
        }) }}

        <div id="cssPath-field"{% if settings.tailwindVersion == '3' %} style="display:none"{% endif %}>
            {{ forms.autosuggestField({
                label: 'CSS Path',
                instructions: 'Directory containing your Tailwind CSS entry file (e.g. the file with `@import "tailwindcss"` or `@theme`). Used for v4 detection. Leave blank to search from the project root.',
                id: 'cssPath',
                name: 'settings[cssPath]',
                value: settings.cssPath,
                placeholder: 'e.g. @root/src/css',
                suggestEnvVars: true,
                suggestAliases: true,
                errors: settings.getErrors('cssPath'),
                disabled: overrides.cssPath is defined or readOnly,
                warning: overrideWarning('cssPath', overrides),
            }) }}
        </div>
    </div>

    {# ===== Output tab ===== #}
    <div id="output" class="hidden">
        {{ forms.autosuggestField({
            label: 'Class Prefix',
            instructions: 'Tailwind class prefix in bare form, no trailing hyphen. v3 projects: the plugin emits `tw-px-4` (matching your `prefix: \'tw-\'` config). v4 projects: the plugin emits `tw:px-4` (matching the v4 `prefix(tw)` CSS directive). Leave blank if you do not use a prefix.',
            id: 'prefix',
            name: 'settings[prefix]',
            value: settings.prefix,
            placeholder: 'e.g. tw',
            suggestEnvVars: true,
            errors: settings.getErrors('prefix'),
            disabled: overrides.prefix is defined or readOnly,
            warning: overrideWarning('prefix', overrides),
        }) }}

        {{ forms.textField({
            label: 'Cache Size',
            instructions: 'Maximum number of merge results to keep in the LRU cache per request. Set to 0 to disable caching.',
            id: 'cacheSize',
            name: 'settings[cacheSize]',
            type: 'number',
            value: settings.cacheSize,
            min: 0,
            max: 10000,
            errors: settings.getErrors('cacheSize'),
            disabled: overrides.cacheSize is defined or readOnly,
            warning: overrideWarning('cacheSize', overrides),
        }) }}

        <hr>

        {% set cssVarRows = [] %}
        {% for key, value in settings.cssVariables %}
            {% set cssVarRows = cssVarRows|merge([{ name: key, value: value }]) %}
        {% endfor %}

        {{ forms.editableTableField({
            label: 'CSS Variables',
            instructions: 'Define CSS custom properties that will be rendered as a `:root` style block. Variable names are automatically prefixed with `--` if missing.',
            id: 'cssVariables',
            name: 'settings[cssVariables]',
            cols: {
                name: {
                    heading: 'Variable Name',
                    type: 'singleline',
                    placeholder: '--color-brand-primary',
                },
                value: {
                    heading: 'Value',
                    type: 'singleline',
                    placeholder: '#3490dc',
                },
            },
            rows: cssVarRows,
            errors: settings.getErrors('cssVariables'),
            allowAdd: true,
            allowDelete: true,
            allowReorder: true,
            disabled: overrides.cssVariables is defined or readOnly,
            warning: overrideWarning('cssVariables', overrides),
        }) }}

        <hr>

        <h2>Auto-Inject</h2>

        <p>Auto-inject renders your CSS variables as a <code>&lt;style&gt;</code> tag in every site page's <code>&lt;head&gt;</code>, so you don't need to call <code>{{ '{{ craft.tailwind.include() }}' }}</code> in your layout. Console and CP requests are never auto-injected.</p>

        <p>If your site uses a dynamic per-request CSP nonce, leave this disabled and call <code>{{ '{{ craft.tailwind.include({ nonce: cspNonce }) }}' }}</code> in your layout instead.</p>

        {{ forms.lightswitchField({
            label: 'Auto-Inject CSS Variables',
            instructions: 'When enabled, the plugin registers the CSS variables style block on every site request automatically.',
            id: 'autoInject',
            name: 'settings[autoInject]',
            on: settings.autoInject,
            errors: settings.getErrors('autoInject'),
            disabled: overrides.autoInject is defined or readOnly,
            warning: overrideWarning('autoInject', overrides),
        }) }}

        {% set attrRows = [] %}
        {% for key, value in settings.autoInjectAttributes %}
            {% set attrRows = attrRows|merge([{ name: key, value: value }]) %}
        {% endfor %}

        {{ forms.editableTableField({
            label: 'Auto-Inject Attributes',
            instructions: 'HTML attributes applied to the auto-injected `<style>` tag. Common keys: `nonce` (for static CSP), `media`.',
            id: 'autoInjectAttributes',
            name: 'settings[autoInjectAttributes]',
            cols: {
                name: {
                    heading: 'Attribute',
                    type: 'singleline',
                    placeholder: 'nonce',
                },
                value: {
                    heading: 'Value',
                    type: 'singleline',
                    placeholder: 'abc123',
                },
            },
            rows: attrRows,
            errors: settings.getErrors('autoInjectAttributes'),
            allowAdd: true,
            allowDelete: true,
            allowReorder: true,
            disabled: overrides.autoInjectAttributes is defined or readOnly,
            warning: overrideWarning('autoInjectAttributes', overrides),
        }) }}
    </div>

    {# ===== Typography tab ===== #}
    <div id="typography" class="hidden">
        <p>Optional support for <a href="https://github.com/tailwindlabs/tailwindcss-typography" target="_blank" rel="noopener">@tailwindcss/typography</a>. When enabled, the merger resolves <code>prose-{size}</code> and <code>prose-{theme}</code> conflicts as mutually-exclusive utility groups — so <code>prose prose-sm prose-lg</code> collapses to <code>prose prose-lg</code>.</p>

        <p>Defaults cover the suffixes shipped by the typography plugin itself (sizes: <code>sm</code>, <code>base</code>, <code>lg</code>, <code>xl</code>, <code>2xl</code>; colors: <code>gray</code>, <code>slate</code>, <code>zinc</code>, <code>neutral</code>, <code>stone</code>, <code>invert</code>). Use the lists below to register any custom suffixes you've added yourself.</p>

        {{ forms.lightswitchField({
            label: 'Resolve Typography Conflicts',
            instructions: 'When enabled, `prose-{size}` and `prose-{theme}` classes merge as conflict groups.',
            id: 'typographyEnabled',
            name: 'settings[typography]',
            on: settings.typography,
            errors: settings.getErrors('typography'),
            disabled: overrides.typography is defined or readOnly,
            warning: overrideWarning('typography', overrides),
        }) }}

        {% set sizeRows = settings.typographyExtraSizes|map(s => { suffix: s }) %}

        {{ forms.editableTableField({
            label: 'Extra Sizes',
            instructions: 'Custom `prose-{size}` suffixes beyond the defaults. Enter without the `prose-` prefix (e.g. `huge` becomes `prose-huge`).',
            id: 'typographyExtraSizes',
            name: 'settings[typographyExtraSizes]',
            cols: {
                suffix: {
                    heading: 'Suffix',
                    type: 'singleline',
                    placeholder: 'huge',
                },
            },
            rows: sizeRows,
            errors: settings.getErrors('typographyExtraSizes'),
            allowAdd: true,
            allowDelete: true,
            allowReorder: true,
            disabled: overrides.typographyExtraSizes is defined or readOnly,
            warning: overrideWarning('typographyExtraSizes', overrides),
        }) }}

        {% set colorRows = settings.typographyExtraColors|map(s => { suffix: s }) %}

        {{ forms.editableTableField({
            label: 'Extra Colors',
            instructions: 'Custom `prose-{color}` or `prose-{theme}` suffixes beyond the defaults. Enter without the `prose-` prefix (e.g. `mybrand` becomes `prose-mybrand`).',
            id: 'typographyExtraColors',
            name: 'settings[typographyExtraColors]',
            cols: {
                suffix: {
                    heading: 'Suffix',
                    type: 'singleline',
                    placeholder: 'mybrand',
                },
            },
            rows: colorRows,
            errors: settings.getErrors('typographyExtraColors'),
            allowAdd: true,
            allowDelete: true,
            allowReorder: true,
            disabled: overrides.typographyExtraColors is defined or readOnly,
            warning: overrideWarning('typographyExtraColors', overrides),
        }) }}
    </div>
{% endblock %}

{% js %}
(function() {
    var versionSelect = document.getElementById('tailwindVersion');
    var cssPathField = document.getElementById('cssPath-field');
    var autoDetectFeedback = document.getElementById('autoDetect-feedback');
    if (!versionSelect) {
        return;
    }
    versionSelect.addEventListener('change', function() {
        if (cssPathField) {
            cssPathField.style.display = this.value === '3' ? 'none' : '';
        }
        if (autoDetectFeedback) {
            autoDetectFeedback.style.display = this.value === 'auto' ? '' : 'none';
        }
    });
})();
{% endjs %}
